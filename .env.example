# Persona Council — environment variables
#
# Copy this file to .env and add at least ONE provider's API key.
# That's all you need to start. The model is picked in the UI from whichever
# providers you've configured a key for.

# ─────────────────────────────────────────────────────────────────────────
# Provider API keys (set at least ONE)
# ─────────────────────────────────────────────────────────────────────────

# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini — https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# OpenRouter (optional) — unlocks Grok, DeepSeek, and acts as multi-provider fallback
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# Advanced (optional — most users won't need these)
# ─────────────────────────────────────────────────────────────────────────
# Set the default council mode for new conversations ("persona", "model", "hybrid").
# Users can override per-conversation in the UI.
# COUNCIL_MODE=persona
